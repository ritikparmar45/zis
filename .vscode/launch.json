{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Start Backend Server",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/backend/server.js",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PORT": "5000",
        "NODE_ENV": "development",
        "CORS_ORIGIN": "*"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Run Test Script",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/backend/test.js",
      "cwd": "${workspaceFolder}/backend"
    }
  ]
}
